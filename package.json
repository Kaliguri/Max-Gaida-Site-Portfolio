  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "serve out -l 3000 --no-clipboard",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
